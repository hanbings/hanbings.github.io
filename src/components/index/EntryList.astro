---
import {convertDateFormat} from '../../utils/date'

export interface EntryListItem {
    title: string
    href: string
    date: string
    tags?: string[]
}

interface Props {
    heading: string
    headingId: string
    items: EntryListItem[]
    class?: string
}

const {heading, headingId, items, class: className} = Astro.props
---

<section class={className} aria-labelledby={headingId}>
    <h2
        id={headingId}
        class="m-0 border-b-0 pb-0 text-xl font-bold leading-[1.4] text-(--theme-fg)"
    >
        {heading}
    </h2>
    <div class="mt-3 flex flex-col">
        {
            items.map((item) => (
                <article class="flex flex-col items-start gap-y-1 py-2 text-(--theme-muted) sm:grid sm:grid-cols-[6.5rem_minmax(0,1fr)] sm:items-baseline sm:gap-x-3 sm:gap-y-1 md:flex md:flex-row md:flex-wrap md:items-center md:gap-3 md:py-0">
                    <time
                        class="font-semibold tabular-nums text-(--theme-fg) sm:font-normal sm:text-(--theme-muted)"
                        datetime={item.date.replace(' ', 'T')}
                    >
                        {convertDateFormat(item.date)}
                    </time>
                    <a class="theme-entry" href={item.href}>
                        {item.title}
                    </a>
                    {item.tags && item.tags.length > 0 && (
                        <div
                            class="mt-1 flex flex-wrap gap-1 text-[0.75rem] sm:col-start-2 md:mt-0"
                            aria-label="标签"
                        >
                            {item.tags.map((tag) => (
                                <a class="theme-muted-link" href={`/tags/${tag}`}>{`#${tag}`}</a>
                            ))}
                        </div>
                    )}
                </article>
            ))
        }
    </div>
</section>
