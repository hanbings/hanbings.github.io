---
import Header from "./Header.astro"
import TableOfContents from "./TableOfContents.astro"

interface Heading {
    depth: number
    slug: string
    text: string
}

const {headings} = Astro.props as {headings: Heading[]}
---

<aside
    class="post-sidebar [&_.theme-title]:bg-transparent [&_.theme-title]:p-0 [&_.theme-title]:text-[1.5rem] [&_.theme-title]:text-[var(--theme-fg)]"
    aria-label="文章导航"
>
    <Header/>
    <a
        class="self-stretch rounded-none border-0 bg-transparent p-0 text-left text-[var(--theme-muted)] no-underline hover:bg-transparent hover:text-[var(--theme-fg)]"
        href="/"
    >返回主页</a>
    <TableOfContents headings={headings}/>
</aside>
