---
type PixelNote = {
    x: number
    y: number
    flag?: boolean
}

type PixelSymbol = 'sharp' | 'rest' | 'double-note'
type FragmentTone = 'ink' | 'coral' | 'blue' | 'teal'

type FragmentLayout = {
    x: number
    y: number
    width: number
    rotation: number
}

const fragmentLayouts: FragmentLayout[] = [
    {x: -8, y: 10, width: 30, rotation: -17},
    {x: 15, y: -5, width: 22, rotation: -10},
    {x: 38, y: 15, width: 34, rotation: -14},
    {x: 64, y: 0, width: 27, rotation: -21},
    {x: 86, y: 20, width: 31, rotation: -11},
    {x: 2, y: 34, width: 26, rotation: -24},
    {x: 24, y: 44, width: 36, rotation: -13},
    {x: 51, y: 31, width: 24, rotation: -18},
    {x: 74, y: 48, width: 33, rotation: -9},
    {x: 97, y: 38, width: 25, rotation: -20},
    {x: -6, y: 65, width: 35, rotation: -12},
    {x: 18, y: 75, width: 23, rotation: -22},
    {x: 42, y: 58, width: 30, rotation: -16},
    {x: 65, y: 78, width: 36, rotation: -10},
    {x: 88, y: 63, width: 24, rotation: -25},
    {x: 5, y: 94, width: 28, rotation: -15},
    {x: 31, y: 87, width: 34, rotation: -8},
    {x: 55, y: 102, width: 22, rotation: -23},
    {x: 80, y: 90, width: 32, rotation: -14},
    {x: 102, y: 105, width: 27, rotation: -19},
]

const notePatterns: PixelNote[][] = [
    [
        {x: 42, y: 112},
        {x: 104, y: 92},
        {x: 166, y: 72, flag: true},
        {x: 238, y: 102},
        {x: 318, y: 82},
    ],
    [
        {x: 36, y: 72, flag: true},
        {x: 96, y: 82},
        {x: 158, y: 102},
        {x: 224, y: 112, flag: true},
        {x: 292, y: 92},
        {x: 350, y: 62},
    ],
    [
        {x: 52, y: 102},
        {x: 118, y: 62},
        {x: 184, y: 82, flag: true},
        {x: 250, y: 72},
        {x: 326, y: 112},
    ],
    [
        {x: 40, y: 92},
        {x: 94, y: 112},
        {x: 150, y: 82},
        {x: 214, y: 62, flag: true},
        {x: 280, y: 72},
        {x: 344, y: 102, flag: true},
    ],
]

const tones: FragmentTone[] = ['ink', 'teal', 'blue', 'coral']
const symbols: PixelSymbol[] = ['sharp', 'double-note', 'rest']
const fragments = fragmentLayouts.map((layout, index) => {
    const standaloneSymbol = index % 4 === 1

    return {
        ...layout,
        tone: tones[index % tones.length] ?? 'ink',
        notes: standaloneSymbol
            ? undefined
            : notePatterns[Math.floor(index / 2) % notePatterns.length],
        symbol: standaloneSymbol ? symbols[index % symbols.length] : undefined,
        staff: !standaloneSymbol,
        mobileHidden: index % 3 === 2,
    }
})
const staffLines = [42, 62, 82, 102, 122]
const streamDuration = 30
const streamCopies = [0, 1]
---

<div
    class="music-background site-background-preset"
    data-background-preset="music"
    style={`--music-stream-duration: ${streamDuration}s`}
    aria-hidden="true"
>
    <div class="music-background-pixel-field music-background-pixel-field-coral"></div>
    <div class="music-background-pixel-field music-background-pixel-field-teal"></div>
    <div class="music-background-pixel-field music-background-pixel-field-blue"></div>
    <div class="music-background-streams">
        {
            streamCopies.map((streamIndex) => (
                <div
                    class="music-background-stream"
                    style={`--music-stream-delay: ${(streamIndex * streamDuration) / -2}s`}
                >
                    {fragments.map((fragment) => (
                        <div
                            class:list={[
                                'music-background-fragment',
                                `music-background-fragment-${fragment.tone}`,
                                fragment.mobileHidden && 'music-background-fragment-mobile-hidden',
                            ]}
                            style={`--fragment-x: ${fragment.x}%; --fragment-y: ${fragment.y}%; --fragment-width: ${fragment.width}vw; --fragment-rotation: ${fragment.rotation}deg`}
                        >
                            <svg
                                class="music-background-fragment-svg"
                                viewBox="0 0 400 164"
                                role="presentation"
                                focusable="false"
                                shape-rendering="crispEdges"
                            >
                                {fragment.staff && (
                                    <g class="music-background-pixel-staff">
                                        {staffLines.map((y, lineIndex) => (
                                            <rect
                                                x={lineIndex % 2 === 0 ? 8 : 28}
                                                y={y}
                                                width={lineIndex % 2 === 0 ? 374 : 342}
                                                height="4"
                                            />
                                        ))}
                                    </g>
                                )}
                                {fragment.notes?.map((note) => (
                                    <g
                                        class="music-background-pixel-note"
                                        transform={`translate(${note.x} ${note.y})`}
                                    >
                                        <path d="M0 4h4V0h18v4h4v12h-4v4H4v-4H0Z" />
                                        <rect x="21" y="-46" width="6" height="56" />
                                        {note.flag && <path d="M27-46h18v6h7v13h-6v7h-7v-13H27Z" />}
                                    </g>
                                ))}
                                {fragment.symbol === 'sharp' && (
                                    <g class="music-background-pixel-symbol music-background-pixel-sharp">
                                        <path d="M142 18h14v38l74-12V8h14v34l28-5v15l-28 5v35l28-5v15l-28 5v39h-14v-36l-74 12v34h-14v-32l-29 5v-15l29-5V74l-29 5V64l29-5Zm14 53v36l74-12V59Z" />
                                    </g>
                                )}
                                {fragment.symbol === 'rest' && (
                                    <g class="music-background-pixel-symbol music-background-pixel-rest">
                                        <path d="M174 8h56v16h-18v20h-18v20h38v18h-20v18h-18v20h20v18h-38v-18h18v-20h-20V82h18V64h-18V46h18V26h-20Z" />
                                    </g>
                                )}
                                {fragment.symbol === 'double-note' && (
                                    <g class="music-background-pixel-symbol music-background-pixel-double-note">
                                        <path d="M108 104h6v-6h26v6h6v20h-6v6h-26v-6h-6Zm122-32h6v-6h26v6h6v20h-6v6h-26v-6h-6ZM140 28h128v18H158v70h-18Zm110 14h18v40h-18Z" />
                                    </g>
                                )}
                            </svg>
                        </div>
                    ))}
                </div>
            ))
        }
    </div>
    <div class="music-background-pixel-grid"></div>
    <div class="music-background-vignette"></div>
</div>
