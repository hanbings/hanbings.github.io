---
type PixelNote = {
    x: number
    y: number
    flag?: boolean
}

type PixelSymbol = 'sharp' | 'rest' | 'double-note'

type MusicFragment = {
    x: number
    y: number
    width: number
    rotation: number
    delay: number
    duration: number
    tone: 'ink' | 'coral' | 'blue' | 'teal'
    notes?: PixelNote[]
    symbol?: PixelSymbol
    staff?: boolean
    mobileHidden?: boolean
}

const fragments: MusicFragment[] = [
    {
        x: -8,
        y: 5,
        width: 34,
        rotation: -17,
        delay: -3,
        duration: 13,
        tone: 'ink',
        staff: true,
        notes: [
            {x: 82, y: 112},
            {x: 168, y: 92, flag: true},
            {x: 268, y: 72},
        ],
    },
    {
        x: 29,
        y: -9,
        width: 20,
        rotation: 11,
        delay: -8,
        duration: 17,
        tone: 'blue',
        symbol: 'sharp',
    },
    {
        x: 58,
        y: 5,
        width: 38,
        rotation: -12,
        delay: -5,
        duration: 15,
        tone: 'teal',
        staff: true,
        notes: [
            {x: 58, y: 72, flag: true},
            {x: 142, y: 92},
            {x: 226, y: 112},
            {x: 318, y: 82, flag: true},
        ],
    },
    {
        x: 87,
        y: 27,
        width: 18,
        rotation: -22,
        delay: -11,
        duration: 19,
        tone: 'coral',
        symbol: 'rest',
        mobileHidden: true,
    },
    {
        x: 8,
        y: 36,
        width: 24,
        rotation: -27,
        delay: -9,
        duration: 14,
        tone: 'coral',
        symbol: 'double-note',
    },
    {
        x: 30,
        y: 31,
        width: 42,
        rotation: -14,
        delay: -1,
        duration: 18,
        tone: 'ink',
        staff: true,
        notes: [
            {x: 48, y: 102},
            {x: 124, y: 82},
            {x: 210, y: 62, flag: true},
            {x: 298, y: 92},
            {x: 354, y: 72},
        ],
    },
    {
        x: 72,
        y: 48,
        width: 27,
        rotation: -8,
        delay: -14,
        duration: 21,
        tone: 'blue',
        staff: true,
        notes: [
            {x: 96, y: 112},
            {x: 202, y: 72, flag: true},
            {x: 306, y: 92},
        ],
    },
    {
        x: -4,
        y: 68,
        width: 23,
        rotation: -19,
        delay: -7,
        duration: 16,
        tone: 'teal',
        symbol: 'sharp',
        mobileHidden: true,
    },
    {
        x: 19,
        y: 64,
        width: 34,
        rotation: -10,
        delay: -12,
        duration: 20,
        tone: 'blue',
        staff: true,
        notes: [
            {x: 72, y: 72},
            {x: 164, y: 102, flag: true},
            {x: 278, y: 82},
        ],
        mobileHidden: true,
    },
    {
        x: 56,
        y: 73,
        width: 21,
        rotation: -25,
        delay: -4,
        duration: 12,
        tone: 'coral',
        symbol: 'double-note',
    },
    {
        x: 78,
        y: 72,
        width: 33,
        rotation: -16,
        delay: -16,
        duration: 22,
        tone: 'ink',
        staff: true,
        notes: [
            {x: 64, y: 112},
            {x: 154, y: 92},
            {x: 246, y: 62},
            {x: 330, y: 82, flag: true},
        ],
    },
    {
        x: 43,
        y: 88,
        width: 16,
        rotation: 8,
        delay: -6,
        duration: 15,
        tone: 'teal',
        symbol: 'rest',
        mobileHidden: true,
    },
]

const staffLines = [42, 62, 82, 102, 122]
---

<div
    class="music-background site-background-preset"
    data-background-preset="music"
    style="--music-pulse-duration: 16s"
    aria-hidden="true"
>
    <div class="music-background-pixel-field music-background-pixel-field-coral"></div>
    <div class="music-background-pixel-field music-background-pixel-field-teal"></div>
    <div class="music-background-pixel-field music-background-pixel-field-blue"></div>
    <div class="music-background-fragments">
        {
            fragments.map((fragment, index) => (
                <div
                    class:list={[
                        'music-background-fragment',
                        `music-background-fragment-${fragment.tone}`,
                        fragment.mobileHidden && 'music-background-fragment-mobile-hidden',
                    ]}
                    style={`--fragment-x: ${fragment.x}%; --fragment-y: ${fragment.y}%; --fragment-width: ${fragment.width}vw; --fragment-rotation: ${fragment.rotation}deg; --fragment-delay: ${fragment.delay}s; --fragment-duration: ${fragment.duration}s; --fragment-step-x: ${(index % 3) * 6 - 6}px; --fragment-step-y: ${(index % 4) * 4 - 6}px`}
                >
                    <svg
                        class="music-background-fragment-svg"
                        viewBox="0 0 400 164"
                        role="presentation"
                        focusable="false"
                        shape-rendering="crispEdges"
                    >
                        {fragment.staff && (
                            <g class="music-background-pixel-staff">
                                {staffLines.map((y, lineIndex) => (
                                    <rect
                                        x={lineIndex % 2 === 0 ? 8 : 28}
                                        y={y}
                                        width={lineIndex % 2 === 0 ? 374 : 342}
                                        height="4"
                                    />
                                ))}
                            </g>
                        )}
                        {fragment.notes?.map((note) => (
                            <g
                                class="music-background-pixel-note"
                                transform={`translate(${note.x} ${note.y})`}
                            >
                                <path d="M0 4h4V0h18v4h4v12h-4v4H4v-4H0Z" />
                                <rect x="21" y="-46" width="6" height="56" />
                                {note.flag && <path d="M27-46h18v6h7v13h-6v7h-7v-13H27Z" />}
                            </g>
                        ))}
                        {fragment.symbol === 'sharp' && (
                            <g class="music-background-pixel-symbol music-background-pixel-sharp">
                                <path d="M142 18h14v38l74-12V8h14v34l28-5v15l-28 5v35l28-5v15l-28 5v39h-14v-36l-74 12v34h-14v-32l-29 5v-15l29-5V74l-29 5V64l29-5Zm14 53v36l74-12V59Z" />
                            </g>
                        )}
                        {fragment.symbol === 'rest' && (
                            <g class="music-background-pixel-symbol music-background-pixel-rest">
                                <path d="M174 8h56v16h-18v20h-18v20h38v18h-20v18h-18v20h20v18h-38v-18h18v-20h-20V82h18V64h-18V46h18V26h-20Z" />
                            </g>
                        )}
                        {fragment.symbol === 'double-note' && (
                            <g class="music-background-pixel-symbol music-background-pixel-double-note">
                                <path d="M108 104h6v-6h26v6h6v20h-6v6h-26v-6h-6Zm122-32h6v-6h26v6h6v20h-6v6h-26v-6h-6ZM140 28h128v18H158v70h-18Zm110 14h18v40h-18Z" />
                            </g>
                        )}
                    </svg>
                </div>
            ))
        }
    </div>
    <div class="music-background-pixel-grid"></div>
    <div class="music-background-vignette"></div>
</div>
