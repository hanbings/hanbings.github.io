<script>
    import {annotate} from 'rough-notation'

    const annotateLink = (link: HTMLAnchorElement) => {
        if (
            link.dataset.markdownLinkAnnotated ||
            link.querySelector('img') ||
            link.querySelector('rough-notation') ||
            link.getClientRects().length === 0
        ) {
            return
        }

        const annotation = annotate(link, {
            type: 'underline',
            color: 'var(--markdown-link-underline)',
            strokeWidth: 2,
            iterations: 2,
            padding: [0, 0, 1, 0],
            animationDuration: 0,
            animate: false,
            multiline: true,
        })
        annotation.show()

        const annotationSvg = link.nextElementSibling
        if (
            !(annotationSvg instanceof SVGElement) ||
            !annotationSvg.classList.contains('rough-annotation')
        ) {
            annotation.remove()
            return
        }

        link.dataset.markdownLinkAnnotated = 'true'
        annotationSvg.setAttribute('aria-hidden', 'true')
        annotationSvg.setAttribute('focusable', 'false')

        let pointerActive = false
        let focusActive = false
        const updateColor = () => {
            annotationSvg.style.setProperty(
                '--markdown-link-underline',
                pointerActive || focusActive ? 'var(--theme-accent)' : 'var(--theme-accent-soft)',
            )
        }

        link.addEventListener('pointerenter', () => {
            pointerActive = true
            updateColor()
        })
        link.addEventListener('pointerleave', () => {
            pointerActive = false
            updateColor()
        })
        link.addEventListener('focus', () => {
            focusActive = true
            updateColor()
        })
        link.addEventListener('blur', () => {
            focusActive = false
            updateColor()
        })
        updateColor()
    }

    const annotateLinks = (root: ParentNode) => {
        const links = root.querySelectorAll<HTMLAnchorElement>('.markdown-body a[href]')
        for (const link of links) annotateLink(link)
    }

    const scheduleAnnotation = (root: ParentNode) => {
        window.requestAnimationFrame(() => annotateLinks(root))
    }

    scheduleAnnotation(document)

    document.addEventListener(
        'toggle',
        (event) => {
            const details = event.target
            if (details instanceof HTMLDetailsElement && details.open) {
                scheduleAnnotation(details)
            }
        },
        true,
    )

    document.addEventListener('astro:page-load', () => {
        scheduleAnnotation(document)
    })
</script>
