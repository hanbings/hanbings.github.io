<dialog class="image-lightbox" aria-label="图片预览">
    <button class="image-lightbox-close" type="button" aria-label="关闭图片预览">
        <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
    </button>
    <img class="image-lightbox-preview" alt="" />
</dialog>

<script>
    const copyText = async (text: string) => {
        if (!navigator.clipboard) {
            throw new Error('Clipboard API is unavailable')
        }

        await navigator.clipboard.writeText(text)
    }

    const copyButtonIcons = {
        copy: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="8" y="8" width="11" height="11" rx="2"></rect><path d="M16 8V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h3"></path></svg>',
        success: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12.5l4 4L19 7"></path></svg>',
        error: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"></path></svg>',
    }

    const setCopyButtonState = (
        button: HTMLButtonElement,
        state: keyof typeof copyButtonIcons,
    ) => {
        const labels = {
            copy: '复制代码',
            success: '代码已复制',
            error: '复制失败',
        }

        const template = document.createElement('template')
        template.innerHTML = copyButtonIcons[state]
        const icon = template.content.firstElementChild
        const currentIcon = button.querySelector(':scope > svg')
        if (icon && currentIcon) currentIcon.replaceWith(icon)
        else if (icon) button.prepend(icon)

        const status = button.querySelector<HTMLElement>('.copy-button-status')
        if (status) status.textContent = state === 'copy' ? '' : labels[state]
        button.setAttribute('aria-label', labels[state])
        button.title = labels[state]
    }

    const enhanceCodeBlocks = () => {
        if (!navigator.clipboard) return

        document.querySelectorAll<HTMLPreElement>('.markdown-body .astro-code').forEach((block) => {
            if (block.dataset.copyReady) return

            const code = block.querySelector('code')
            if (!code) return

            const button = document.createElement('button')
            button.type = 'button'
            button.className = 'code-copy-button'

            const status = document.createElement('span')
            status.className = 'copy-button-status'
            status.setAttribute('role', 'status')
            status.setAttribute('aria-atomic', 'true')
            button.append(status)
            setCopyButtonState(button, 'copy')

            let resetTimer: number | undefined
            button.addEventListener('click', async () => {
                window.clearTimeout(resetTimer)
                button.disabled = true

                try {
                    await copyText(code.textContent ?? '')
                    setCopyButtonState(button, 'success')
                } catch {
                    setCopyButtonState(button, 'error')
                } finally {
                    button.disabled = false
                }

                resetTimer = window.setTimeout(() => {
                    setCopyButtonState(button, 'copy')
                }, 1800)
            })

            const wrapper = document.createElement('div')
            wrapper.className = 'code-block-wrapper'
            block.dataset.copyReady = 'true'
            block.before(wrapper)
            wrapper.append(block, button)
        })
    }

    const enhanceImages = () => {
        const dialog = document.querySelector<HTMLDialogElement>('.image-lightbox')
        const preview = dialog?.querySelector<HTMLImageElement>('.image-lightbox-preview')
        const closeButton = dialog?.querySelector<HTMLButtonElement>('.image-lightbox-close')
        if (!dialog || !preview || !closeButton) return

        let trigger: HTMLImageElement | undefined
        let scrollX = 0
        let scrollY = 0
        let scrollLocked = false
        const bodyStyleBeforeLock = {
            position: '',
            top: '',
            left: '',
            width: '',
            overflow: '',
        }

        const lockScroll = () => {
            const { style } = document.body
            bodyStyleBeforeLock.position = style.position
            bodyStyleBeforeLock.top = style.top
            bodyStyleBeforeLock.left = style.left
            bodyStyleBeforeLock.width = style.width
            bodyStyleBeforeLock.overflow = style.overflow
            style.position = 'fixed'
            style.top = `-${scrollY}px`
            style.left = `-${scrollX}px`
            style.width = '100%'
            style.overflow = 'hidden'
            scrollLocked = true
        }

        const restoreScroll = () => {
            if (!scrollLocked) return

            const { style } = document.body
            style.position = bodyStyleBeforeLock.position
            style.top = bodyStyleBeforeLock.top
            style.left = bodyStyleBeforeLock.left
            style.width = bodyStyleBeforeLock.width
            style.overflow = bodyStyleBeforeLock.overflow
            scrollLocked = false
            window.scrollTo(scrollX, scrollY)
        }

        const closeDialog = () => {
            if (dialog.open) dialog.close()
        }

        const openImage = (image: HTMLImageElement) => {
            const source = image.currentSrc || image.src
            if (typeof dialog.showModal !== 'function') {
                window.open(source, '_blank', 'noopener,noreferrer')
                return
            }

            trigger = image
            scrollX = window.scrollX
            scrollY = window.scrollY
            preview.src = source
            dialog.setAttribute('aria-label', `图片预览：${image.alt}`)

            try {
                dialog.showModal()
                lockScroll()
            } catch {
                preview.removeAttribute('src')
                window.open(source, '_blank', 'noopener,noreferrer')
            }
        }

        document.querySelectorAll<HTMLImageElement>('.markdown-body img').forEach((image) => {
            if (!image.alt.trim() || image.closest('a') || image.dataset.lightboxReady) return

            image.dataset.lightboxReady = 'true'
            image.classList.add('zoomable-image')
            image.tabIndex = 0
            image.setAttribute('role', 'button')
            image.setAttribute('aria-haspopup', 'dialog')
            image.setAttribute('aria-label', `放大图片：${image.alt}`)
            image.addEventListener('click', () => openImage(image))
            image.addEventListener('keydown', (event) => {
                if (event.key !== 'Enter' && event.key !== ' ') return
                event.preventDefault()
                openImage(image)
            })
        })

        closeButton.addEventListener('click', closeDialog)
        dialog.addEventListener('click', (event) => {
            if (event.target === dialog) closeDialog()
        })
        dialog.addEventListener('close', () => {
            preview.removeAttribute('src')
            restoreScroll()
            trigger?.focus({ preventScroll: true })
            window.requestAnimationFrame(() => window.scrollTo(scrollX, scrollY))
        })
    }

    enhanceCodeBlocks()
    enhanceImages()
</script>
