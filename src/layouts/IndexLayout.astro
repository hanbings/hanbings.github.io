---
import SiteLayout from './SiteLayout.astro'

const {title, background} = Astro.props as {
    title: string
    background?: string
}
---

<SiteLayout title={title} background={background}>
    <slot name="backfill-background" slot="backfill-background" />
    <slot name="header-background" slot="header-background" />
    <slot name="site-overlay" slot="site-overlay" />
    <main class="site-main mx-auto w-[min(720px,calc(100%-3rem))] py-3" data-site-region="main">
        <div class="w-full max-w-180">
            <slot />
        </div>
    </main>
</SiteLayout>
