---
import SiteLayout from './SiteLayout.astro'

const {title, background} = Astro.props as {
    title: string
    background?: string
}
---

<SiteLayout title={title} background={background} markdownRender>
    <slot name="backfill-background" slot="backfill-background" />
    <slot name="header-background" slot="header-background" />
    <slot name="site-overlay" slot="site-overlay" />
    <main class="markdown-render" data-site-region="main" aria-label={title}>
        <article
            class="markdown-render-main w-full max-w-180 flex flex-col gap-4"
            data-site-region="article"
        >
            <slot />
        </article>
        <div class="markdown-render-region markdown-render-left" data-site-region="left">
            <slot name="left" />
        </div>
        <div class="markdown-render-region markdown-render-right" data-site-region="right">
            <slot name="right" />
        </div>
    </main>
</SiteLayout>
