---
import Meta from "../components/Meta.astro"
import Header from "../components/Header.astro"
import Navigation from "../components/Navigation.astro"
import Footer from "../components/Footer.astro"
import ContentEnhancements from "../components/ContentEnhancements.astro"
import "../styles/global.css"

const {title, post = false} = Astro.props as {title: string, post?: boolean}
---
<!doctype html>
<html lang="zh-CN">
    <head>
        <Meta title={title}/>
    </head>
    <body>
        <div class="min-h-lvh w-full site-page-shell">
            <header class={`site-page-header${post ? ' post-page-header' : ''}`}>
                <Header/>
            </header>
            <nav class={`site-page-navigation${post ? ' post-page-navigation' : ''}`} aria-label="主导航">
                <Navigation/>
            </nav>
            <main class={`site-page-main${post ? ' post-page-main' : ''}`}>
                <article class="w-full max-w-[720px] flex flex-col gap-4">
                    <slot/>
                </article>
            </main>
            <footer class="site-page-footer">
                <Footer/>
            </footer>
        </div>
        <ContentEnhancements/>
    </body>
</html>
