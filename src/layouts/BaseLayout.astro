---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import Navigation from "../components/Navigation.astro"
import Meta from "../components/Meta.astro"
import ContentEnhancements from "../components/ContentEnhancements.astro"
import "../styles/global.css"

const {title} = Astro.props as {title: string}
---
<!doctype html>
<html lang="zh-CN">
    <head>
        <Meta title={title}/>
    </head>
    <body>
        <div class="min-h-lvh w-full site-page-shell">
            <header class="site-page-header">
                <Header/>
            </header>
            <nav class="site-page-navigation" aria-label="主导航">
                <Navigation/>
            </nav>
            <main class="site-page-main">
                <div class="w-full max-w-[720px]">
                    <slot/>
                </div>
            </main>
            <footer class="site-page-footer">
                <Footer/>
            </footer>
        </div>
        <ContentEnhancements/>
    </body>
</html>
