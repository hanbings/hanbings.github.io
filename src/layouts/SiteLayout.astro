---
import Meta from '../components/site/Meta.astro'
import Header from '../components/site/Header.astro'
import Navigation from '../components/site/Navigation.astro'
import Footer from '../components/site/Footer.astro'
import BackfillBackground from '../components/site/BackfillBackground.astro'
import '../styles/global.css'

const {
    title,
    background,
    markdownRender = false,
} = Astro.props as {
    title: string
    background?: string
    markdownRender?: boolean
}
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <Meta title={title} />
    </head>
    <body>
        <div class="site-foreground relative min-h-lvh w-full isolate" data-site-root>
            <div
                class="site-background pointer-events-none absolute inset-0 z-0 min-h-full overflow-hidden"
                data-site-region="background"
                aria-hidden="true"
            >
                <BackfillBackground />
                <slot name="backfill-background" />
                <div class="site-background-header" data-site-region="header-background">
                    {background && <img src={background} alt="" decoding="async" />}
                    <slot name="header-background" />
                </div>
            </div>
            <div class="site-content relative z-1" data-site-region="content">
                <header
                    data-site-region="header"
                    class:list={[
                        'site-header mx-auto w-[min(720px,calc(100%-3rem))] pt-[25dvh]',
                        markdownRender &&
                            'markdown-render-page-header [&_.theme-title]:bg-transparent [&_.theme-title]:p-0 [&_.theme-title]:text-[1.5rem] [&_.theme-title]:text-(--theme-fg)',
                    ]}
                >
                    <Header />
                </header>
                <nav
                    data-site-region="navigation"
                    class:list={[
                        'site-navigation mx-auto w-[min(720px,calc(100%-3rem))] py-2',
                        markdownRender && 'hidden',
                    ]}
                    aria-label="主导航"
                >
                    <Navigation />
                </nav>
                <slot />
                <footer
                    class="site-footer mx-auto w-[min(720px,calc(100%-3rem))] pt-2 pb-6"
                    data-site-region="footer"
                >
                    <Footer />
                </footer>
            </div>
            <div
                class="site-overlay pointer-events-none absolute inset-0 z-2"
                data-site-region="overlay"
            >
                <slot name="site-overlay" />
            </div>
        </div>
    </body>
</html>
