---
import IndexLayout from '../layouts/IndexLayout.astro'
import EntryList from '../components/index/EntryList.astro'
import {getCollection} from 'astro:content'

const allPosts = (await getCollection('posts', ({data}) => !data.draft)).sort(
    (a, b) =>
        new Date(b.data.date.replace(' ', 'T')).getTime() -
        new Date(a.data.date.replace(' ', 'T')).getTime(),
)
---

<IndexLayout title="文章">
    <EntryList
        heading="文章"
        headingId="posts-title"
        items={allPosts.map((post) => ({
            title: post.data.title,
            href: `/posts/${post.id}`,
            date: post.data.date,
            tags: post.data.tags,
        }))}
    />
</IndexLayout>
