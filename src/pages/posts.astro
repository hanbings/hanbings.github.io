---
import PostLayout from "../layouts/PostLayout.astro"
import {getCollection} from "astro:content"
import {convertDateFormat} from "../utils/date"

const allPosts =
    (await getCollection('posts', ({ data }) => !data.draft))
        .sort((a, b) =>
            new Date(b.data.date.replace(" ", "T")).getTime() -
            new Date(a.data.date.replace(" ", "T")).getTime())
---
<PostLayout title="文章">
    <section aria-labelledby="posts-title">
        <h2
            id="posts-title"
            class="m-0 border-b-0 pb-0 text-xl font-bold leading-[1.4] text-[var(--theme-fg)]"
        >文章</h2>
        <div class="mt-3 flex flex-col gap-0">
            {
                allPosts.map(post => (
                    <article class="flex flex-row flex-wrap items-center gap-3 text-[var(--theme-muted)]">
                        <time datetime={post.data.date.replace(" ", "T")}>{convertDateFormat(post.data.date)}</time>
                        <a
                            class="text-inherit no-underline hover:underline hover:decoration-2 hover:decoration-[var(--theme-accent)] hover:underline-offset-[3px]"
                            href={`/posts/${post.id}`}
                        >{post.data.title}</a>
                        <div class="flex flex-wrap gap-1 [font-size:0.75rem]" aria-label="标签">
                            {
                                post.data.tags.map(tag => (
                                    <a class="theme-muted-link" href={`/tags/${tag}`}>{`#${tag}`}</a>
                                ))
                            }
                        </div>
                    </article>
                ))
            }
        </div>
    </section>
</PostLayout>
