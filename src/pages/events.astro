---
import IndexLayout from '../layouts/IndexLayout.astro'
import EntryList from '../components/index/EntryList.astro'
import {getCollection} from 'astro:content'

const allEvents = (await getCollection('events', ({data}) => !data.draft)).sort(
    (a, b) =>
        new Date(b.data.date.replace(' ', 'T')).getTime() -
        new Date(a.data.date.replace(' ', 'T')).getTime(),
)
---

<IndexLayout title="Events">
    <EntryList
        heading="Events"
        headingId="events-title"
        items={allEvents.map((event) => ({
            title: event.data.title,
            href: `/events/${event.id}`,
            date: event.data.date,
        }))}
    />
</IndexLayout>
