---
import {getCollection, render} from 'astro:content'
import PostLayout from '../../layouts/PostLayout.astro'
import PostSidebar from '../../components/post/PostSidebar.astro'
import TableOfContents from '../../components/post/TableOfContents.astro'
import HandDrawnHighlightLink from '../../components/site/HandDrawnHighlightLink.astro'
import {mdxComponents} from '../../components/mdx'
import '../../styles/markdown/github.css'

export async function getStaticPaths() {
    const blogEntries = await getCollection('posts')
    return blogEntries.map((entry) => ({
        params: {slug: entry.id},
        props: {entry},
    }))
}

const {entry} = Astro.props
const {Content, headings} = await render(entry)
const tags = [...entry.data['tags']]
---

<PostLayout
    title={entry.data['title']}
    background={entry.data['background']}
    backgroundOpacity={entry.data['backgroundOpacity']}
>
    <PostSidebar slot="left" headings={headings} />
    {
        entry.data['draft'] && (
            <aside
                class="rounded-lg border border-(--theme-accent) bg-(--theme-accent-soft) px-4 py-3 text-(--theme-fg)"
                aria-label="草稿状态"
            >
                这篇文章还在施工中，内容可能随时变化
            </aside>
        )
    }
    <h1 class="text-2xl font-bold">{entry.data['title']}</h1>
    <div class="flex flex-col">
        <div class="flex flex-row items-center gap-2">
            <span aria-hidden="true" class="leading-none">🐱</span>
            <span class="text-(--theme-muted)">{entry.data['author']}</span>
        </div>
        <div class="flex flex-row flex-wrap items-center gap-2">
            <span aria-hidden="true" class="leading-none">🏷</span>
            {
                tags.map((tag) => (
                    <HandDrawnHighlightLink href={`/tags/${tag}`}>
                        {`#${tag}`}
                    </HandDrawnHighlightLink>
                ))
            }
        </div>
    </div>
    <div class="post-toc-mobile flex flex-col items-start gap-3" aria-label="文章导航">
        <HandDrawnHighlightLink class="self-start text-left" href="/">
            返回主页
        </HandDrawnHighlightLink>
        <TableOfContents headings={headings} />
    </div>
    <div class="markdown-body">
        <Content components={mdxComponents} />
    </div>
</PostLayout>
