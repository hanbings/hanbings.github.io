---
import {getCollection, render} from 'astro:content'
import PostLayout from '../../layouts/PostLayout.astro'
import PostSidebar from '../../components/post/PostSidebar.astro'
import TableOfContents from '../../components/post/TableOfContents.astro'
import {mdxComponents} from '../../components/mdx'
import '../../styles/markdown/github.css'

export async function getStaticPaths() {
    const blogEntries = await getCollection('posts', ({data}) => !data.draft)
    return blogEntries.map((entry) => ({
        params: {slug: entry.id},
        props: {entry},
    }))
}

const {entry} = Astro.props
const {Content, headings} = await render(entry)
const tags = [...entry.data['tags']]
---

<PostLayout
    title={entry.data['title']}
    background={entry.data['background']}
    backgroundOpacity={entry.data['backgroundOpacity']}
>
    <PostSidebar slot="left" headings={headings} />
    <h1 class="text-2xl font-bold">{entry.data['title']}</h1>
    <div class="flex flex-col">
        <div class="flex flex-row items-center gap-2">
            <span aria-hidden="true" class="leading-none">🐱</span>
            <span class="text-(--theme-muted)">{entry.data['author']}</span>
        </div>
        <div class="flex flex-row flex-wrap items-center gap-2">
            <span aria-hidden="true" class="leading-none">🏷</span>
            {tags.map((tag) => <a href={`/tags/${tag}`} class="theme-muted-link">{`#${tag}`}</a>)}
        </div>
    </div>
    <div class="post-toc-mobile flex flex-col items-start gap-3" aria-label="文章导航">
        <a class="theme-entry self-start text-left" href="/">返回主页</a>
        <TableOfContents headings={headings} />
    </div>
    <div class="markdown-body">
        <Content components={mdxComponents} />
    </div>
</PostLayout>
