---
import BaseLayout from "../layouts/BaseLayout.astro"
import {convertDateFormat} from "../utils/date"
import {getCollection} from "astro:content"

const allPosts =
    (await getCollection('posts', ({ data }) => !data.draft))
        .sort((a, b) =>
            new Date(b.data.date.replace(" ", "T")).getTime() -
            new Date(a.data.date.replace(" ", "T")).getTime())
---
<BaseLayout title="主页">
    <section class="home-recent" aria-labelledby="recent-posts-title">
        <h2 id="recent-posts-title" class="page-title">近期文章</h2>
        <div class="home-post-list flex flex-col gap-0">
            {
                allPosts.map(post => (
                    <article class="home-post flex flex-row flex-wrap gap-3 items-center">
                        <time datetime={post.data.date.replace(" ", "T")}>{convertDateFormat(post.data.date)}</time>
                        <a class="home-post-title" href={`/posts/${post.id}`}>{post.data.title}</a>
                        <div class="home-post-tags" aria-label="标签">
                            {
                                post.data.tags.map(tag => (
                                    <a class="theme-muted-link" href={`/tags/${tag}`}>{`#${tag}`}</a>
                                ))
                            }
                        </div>
                    </article>
                ))
            }
        </div>
    </section>
</BaseLayout>
