---
import {getCollection, render} from 'astro:content'
import EventLayout from '../../layouts/EventLayout.astro'
import MarkdownLinkAnnotations from '../../components/mdx/MarkdownLinkAnnotations.astro'
import {mdxComponents} from '../../components/mdx'
import '../../styles/markdown/github.css'

export async function getStaticPaths() {
    const blogEntries = await getCollection('events', ({data}) => !data.draft)
    return blogEntries.map((entry) => ({
        params: {slug: entry.id},
        props: {entry},
    }))
}

const {entry} = Astro.props
const {Content} = await render(entry)
---

<EventLayout
    title={entry.data['title']}
    background={entry.data['background']}
    backgroundOpacity={entry.data['backgroundOpacity']}
>
    <Content components={mdxComponents} />
    <MarkdownLinkAnnotations />
</EventLayout>
