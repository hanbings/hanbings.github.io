---
import {getCollection} from "astro:content"
import {convertDateFormat} from "../../utils/date"
import PostLayout from "../../layouts/PostLayout.astro"

export async function getStaticPaths() {
    const allPosts = await getCollection('posts', ({ data }) => !data.draft)

    const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))]

    return allTags.map((tag) => {
        const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag))
        return {
            params: {tag},
            props: {posts: filteredPosts},
        };
    });
}

const {tag} = Astro.params
const {posts} = Astro.props
---
<PostLayout title={tag}>
    <section class="mt-0" aria-labelledby="tag-posts-title">
        <h2
            id="tag-posts-title"
            class="m-0 border-b-0 pb-0 text-xl font-bold leading-[1.4] text-(--theme-fg)"
        >包含「{tag}」标签的文章</h2>
        <div class="mt-3 flex flex-col gap-0">
            {
                posts.map(post => (
                    <article class="flex flex-row flex-wrap items-center gap-3 text-(--theme-muted)">
                        <time class="tabular-nums" datetime={post.data.date.replace(" ", "T")}>{convertDateFormat(post.data.date)}</time>
                        <a
                            class="text-inherit no-underline hover:underline hover:decoration-2 hover:decoration-(--theme-accent) hover:underline-offset-[3px]"
                            href={`/posts/${post.id}`}
                        >{post.data.title}</a>
                        <div class="flex flex-wrap gap-1 text-[0.75rem]" aria-label="标签">
                            {
                                post.data.tags.map(postTag => (
                                    <a class="theme-muted-link" href={`/tags/${postTag}`}>{`#${postTag}`}</a>
                                ))
                            }
                        </div>
                    </article>
                ))
            }
        </div>
    </section>
</PostLayout>